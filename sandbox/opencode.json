{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "llm-proxy": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Axone llm-proxy",
      "options": {
        "baseURL": "{env:LLM_PROXY_BASE_URL}",
        "apiKey": "{env:LLM_PROXY_API_KEY}"
      },
      "models": {
        "eco": { "name": "Eco tier" },
        "frontier": { "name": "Frontier tier" }
      }
    }
  },
  "mcp": {
    "mcp-gateway": {
      "type": "remote",
      "url": "https://mcp-gateway.internal:8443/mcp",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:TASK_JWT}"
      }
    }
  },
  "tools": {
    "github*": true,
    "browser*": true,
    "database*": true,
    "m365*": true,
    "slack*": true,
    "notion*": true
  }
}
