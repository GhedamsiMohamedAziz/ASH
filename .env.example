# Copy to .env for local development.  Dev-only values — never commit real secrets.

# --- Postgres (pgvector) ---
POSTGRES_USER=olma
POSTGRES_PASSWORD=olma
POSTGRES_DB=olma
DATABASE_URL=postgresql://olma:olma@localhost:5432/olma

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- NATS JetStream ---
NATS_URL=nats://localhost:4222

# --- Vault (dev mode) ---
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev
# MCP Gateway AES-256 vault key (64 hex chars). Connector OAuth tokens are sealed with this key and
# persisted (ciphertext-only) to backend-core, so it MUST be stable across gateway restarts for a
# connection to rehydrate — a changed/unset key makes prior ciphertext unreadable ("key rotated").
# Prod sources this from HashiCorp Vault; unset in dev falls back to a random per-boot key (no
# durability). Generate: python3 -c "import secrets;print(secrets.token_hex(32))"
# GATEWAY_VAULT_KEY=REPLACE_WITH_64_HEX_CHARS

# --- Trigger.dev (self-hosted) ---
TRIGGER_API_URL=http://localhost:8030

# --- LLM proxy (LiteLLM) — §9.5 / Annexe H ---
ANTHROPIC_API_KEY=REPLACE_WITH_YOUR_ANTHROPIC_KEY
# LLM_PROXY_URL=http://localhost:4000

# --- Auth / JWT (§13.4, §8.1) ---
JWT_ISSUER=olma-auth
JWT_AUDIENCE=olma-internal
# JWKS_URL=http://localhost:8001/.well-known/jwks.json

# --- Vector DB (blueprint semantic index) ---
OLMA_VECTORDB_PATH=./vectordb/chroma
