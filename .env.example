# Copy to .env for local development.  Dev-only values — never commit real secrets.

# --- Postgres (pgvector) ---
POSTGRES_USER=olma
POSTGRES_PASSWORD=olma
POSTGRES_DB=olma
DATABASE_URL=postgresql://olma:olma@localhost:5432/olma

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- NATS JetStream ---
NATS_URL=nats://localhost:4222

# --- Vault (dev mode) ---
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev

# --- Trigger.dev (self-hosted) ---
TRIGGER_API_URL=http://localhost:8030

# --- LLM proxy (LiteLLM) — §9.5 / Annexe H ---
# ANTHROPIC_API_KEY=
# LLM_PROXY_URL=http://localhost:4000

# --- Auth / JWT (§13.4, §8.1) ---
JWT_ISSUER=olma-auth
JWT_AUDIENCE=olma-internal
# JWKS_URL=http://localhost:8001/.well-known/jwks.json

# --- Vector DB (blueprint semantic index) ---
OLMA_VECTORDB_PATH=./vectordb/chroma
